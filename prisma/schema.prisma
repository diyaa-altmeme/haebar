generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String             @id @default(uuid()) @db.Uuid
  name              String             @db.VarChar(100)
  email             String             @unique @db.VarChar(150)
  passwordHash      String             @map("password_hash") @db.VarChar(255)
  role              UserRole
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  transfers         BoxTransfer[]      @relation("authorizedBy")
  expenses          Expense[]
  monthConfig       MonthlySetting[]
  refreshTokens     RefreshToken[]
  sales             Sale[]
  auditLogs         AuditLog[]
  recalculationRuns RecalculationRun[] @relation("triggeredBy")

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model Employee {
  id            String         @id @default(uuid()) @db.Uuid
  name          String         @db.VarChar(100)
  cashierNumber Int            @map("cashier_number")
  shift         ShiftType
  employeeType  EmployeeType   @map("employee_type")
  phone         String?        @db.VarChar(20)
  salary        Decimal        @default(0) @db.Decimal(18, 3)
  status        EmployeeStatus @default(active)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  sales         Sale[]

  @@map("employees")
}

model Sale {
  id              String          @id @default(uuid()) @db.Uuid
  saleDate        DateTime        @map("sale_date") @db.Date
  dayNumber       Int             @map("day_number")
  month           Int
  year            Int
  employeeId      String          @map("employee_id") @db.Uuid
  cashierNumber   Int             @map("cashier_number")
  shift           ShiftType
  cashSystem      Decimal         @default(0) @map("cash_system") @db.Decimal(18, 3)
  returns         Decimal         @default(0) @db.Decimal(18, 3)
  netCashSystem   Decimal         @default(0) @map("net_cash_system") @db.Decimal(18, 3)
  masterSystem    Decimal         @default(0) @map("master_system") @db.Decimal(18, 3)
  swishSystem     Decimal         @default(0) @db.Decimal(18, 3)
  sagiSystem      Decimal         @default(0) @db.Decimal(18, 3)
  otherElecSystem Decimal         @default(0) @map("other_elec_system") @db.Decimal(18, 3)
  totalElecSystem Decimal         @default(0) @map("total_elec_system") @db.Decimal(18, 3)
  totalNetSystem  Decimal         @default(0) @map("total_net_system") @db.Decimal(18, 3)
  cashActual      Decimal         @default(0) @map("cash_actual") @db.Decimal(18, 3)
  masterActual    Decimal         @default(0) @map("master_actual") @db.Decimal(18, 3)
  swishActual     Decimal         @default(0) @db.Decimal(18, 3)
  sagiActual      Decimal         @default(0) @db.Decimal(18, 3)
  otherElecActual Decimal         @default(0) @map("other_elec_actual") @db.Decimal(18, 3)
  totalElecActual Decimal         @default(0) @map("total_elec_actual") @db.Decimal(18, 3)
  totalActual     Decimal         @default(0) @map("total_actual") @db.Decimal(18, 3)
  diffCash        Decimal         @default(0) @map("diff_cash") @db.Decimal(18, 3)
  diffElec        Decimal         @default(0) @map("diff_elec") @db.Decimal(18, 3)
  diffTotal       Decimal         @default(0) @map("diff_total") @db.Decimal(18, 3)
  notes           String?
  enteredBy       String?         @map("entered_by") @db.Uuid
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  entryTime       String?         @map("entry_time") @db.VarChar(10)
  cashBreakdown   CashBreakdown[]
  employee        Employee        @relation(fields: [employeeId], references: [id])
  enteredByUser   User?           @relation(fields: [enteredBy], references: [id])

  @@unique([saleDate, cashierNumber, shift])
  @@index([month, year])
  @@index([saleDate])
  @@index([employeeId])
  @@map("sales")
}

model CashBreakdown {
  id           String  @id @default(uuid()) @db.Uuid
  saleId       String  @map("sale_id") @db.Uuid
  denomination Int
  count        Int
  subtotal     Decimal @default(0) @db.Decimal(18, 3)
  sale         Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@map("cash_breakdown")
}

model Expense {
  id            String        @id @default(uuid()) @db.Uuid
  expenseDate   DateTime      @map("expense_date") @db.Date
  dayNumber     Int           @map("day_number")
  month         Int
  year          Int
  category      String        @db.VarChar(100)
  subCategory   String?       @map("sub_category") @db.VarChar(100)
  description   String?
  amount        Decimal       @db.Decimal(18, 3)
  paymentSource BoxType       @map("payment_source")
  paymentMethod PaymentMethod @map("payment_method")
  status        ExpenseStatus
  notes         String?
  enteredBy     String?       @map("entered_by") @db.Uuid
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  enteredByUser User?         @relation(fields: [enteredBy], references: [id])

  @@index([month, year])
  @@index([expenseDate])
  @@index([category])
  @@map("expenses")
}

model BoxBalance {
  id                String   @id @default(uuid()) @db.Uuid
  boxType           BoxType  @map("box_type")
  month             Int
  year              Int
  openingBalance    Decimal  @default(0) @map("opening_balance") @db.Decimal(18, 3)
  incomeSystem      Decimal  @default(0) @map("income_system") @db.Decimal(18, 3)
  incomeActual      Decimal  @default(0) @map("income_actual") @db.Decimal(18, 3)
  totalExpenses     Decimal  @default(0) @map("total_expenses") @db.Decimal(18, 3)
  transfersIn       Decimal  @default(0) @map("transfers_in") @db.Decimal(18, 3)
  transfersOut      Decimal  @default(0) @map("transfers_out") @db.Decimal(18, 3)
  calculatedBalance Decimal  @default(0) @map("calculated_balance") @db.Decimal(18, 3)
  actualBalance     Decimal? @map("actual_balance") @db.Decimal(18, 3)
  difference        Decimal? @default(0) @db.Decimal(18, 3)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([boxType, month, year])
  @@map("box_balances")
}

model BoxTransfer {
  id               String   @id @default(uuid()) @db.Uuid
  fromBox          BoxType  @map("from_box")
  toBox            BoxType  @map("to_box")
  amount           Decimal  @db.Decimal(18, 3)
  transferDate     DateTime @map("transfer_date") @db.Date
  month            Int
  year             Int
  reason           String?
  authorizedBy     String?  @map("authorized_by") @db.Uuid
  isConfirmed      Boolean  @default(false) @map("is_confirmed")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  authorizedByUser User?    @relation("authorizedBy", fields: [authorizedBy], references: [id])

  @@index([month, year])
  @@index([transferDate])
  @@map("box_transfers")
}

model ExpenseCategory {
  id                  String  @id @default(uuid()) @db.Uuid
  name                String  @unique @db.VarChar(100)
  isCompanySettlement Boolean @default(false) @map("is_company_settlement")
  isActive            Boolean @default(true) @map("is_active")
  displayOrder        Int     @default(0) @map("display_order")

  @@map("expense_categories")
}

model MonthlySetting {
  id          String  @id @default(uuid()) @db.Uuid
  month       Int
  year        Int
  daysInMonth Int     @map("days_in_month")
  isActive    Boolean @default(false) @map("is_active")
  createdBy   String? @map("created_by") @db.Uuid
  creator     User?   @relation(fields: [createdBy], references: [id])

  @@unique([month, year])
  @@map("monthly_settings")
}

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  entityType String      @map("entity_type") @db.VarChar(50)
  entityId   String?     @map("entity_id") @db.Uuid
  action     AuditAction
  actorId    String?     @map("actor_id") @db.Uuid
  beforeData Json?       @map("before_data")
  afterData  Json?       @map("after_data")
  metadata   Json?
  createdAt  DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  actor      User?       @relation(fields: [actorId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model RecalculationRun {
  id          String              @id @default(uuid()) @db.Uuid
  month       Int
  year        Int
  boxType     BoxType?            @map("box_type")
  status      RecalculationStatus
  notes       String?
  startedAt   DateTime            @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt  DateTime?           @map("finished_at") @db.Timestamptz(6)
  summary     Json?
  triggeredBy String?             @map("triggered_by") @db.Uuid
  triggerUser User?               @relation("triggeredBy", fields: [triggeredBy], references: [id])

  @@index([month, year])
  @@index([startedAt])
  @@map("recalculation_runs")
}

enum UserRole {
  admin
  manager
  data_entry
}

enum ShiftType {
  morning
  evening
  night
}

enum EmployeeType {
  cashier
  accounting
  treasury
  manager
}

enum EmployeeStatus {
  active
  leave
  suspended
}

enum PaymentMethod {
  cash
  check
  transfer
  card
}

enum ExpenseStatus {
  paid
  pending
  late
}

enum BoxType {
  cash
  master
  swish
  sagi
  other_elec
  bank
}

enum AuditAction {
  create
  update
  delete
  recalculate
}

enum RecalculationStatus {
  running
  completed
  failed
}
